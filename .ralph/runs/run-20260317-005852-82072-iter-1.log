+#!/usr/bin/env bash
+
+set -euo pipefail
+
+ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+ACTIVITY_LOG="$ROOT_DIR/.ralph/activity.log"
+
+if [[ "${1:-}" != "log" || $# -lt 2 ]]; then
+  echo "Usage: $0 log \"message\"" >&2
+  exit 1
+fi
