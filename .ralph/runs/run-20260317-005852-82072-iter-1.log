+
+    expect([...PLUGIN_CONFIG_KEYS]).toEqual(requiredKeys);
+    expect(Object.keys(DEFAULT_PLUGIN_CONFIG) as Array<(typeof PLUGIN_CONFIG_KEYS)[number]>).toEqual(requiredKeys);
+  });
+
+  test("exposes the scaffold defaults", () => {
