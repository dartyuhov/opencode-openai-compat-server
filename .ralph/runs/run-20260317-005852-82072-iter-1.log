+  host: string;
+  port: number;
+  apiKey: string | null;
+  upstreamBaseUrl: string | null;
+  upstreamUsername: string | null;
+  upstreamPassword: string | null;
+  defaultAgent: string;
+  requestTimeoutMs: number;
+  modelsCacheTtlMs: number;
+};
+
+// Later stories will validate and apply these defaults at runtime.
