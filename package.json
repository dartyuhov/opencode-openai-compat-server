{
  "name": "opencode-openai-compat",
  "version": "0.1.0",
  "description": "OpenCode plugin that exposes an OpenAI-compatible sidecar API.",
  "keywords": [
    "opencode",
    "plugin",
    "openai-compatible",
    "bun"
  ],
  "type": "module",
  "license": "MIT",
  "packageManager": "bun@1.3.10",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run scripts/check-plugin-packaging.ts && rm -rf dist && tsc -p tsconfig.build.json",
    "serve:compat": "bun run scripts/serve-with-sidecar.ts",
    "test": "bun test",
    "typecheck": "bun run scripts/check-plugin-packaging.ts && tsc --noEmit -p tsconfig.json",
    "test:e2e:real": "bun run scripts/test-e2e-real.ts"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "1.2.27",
    "@types/bun": "^1.3.10",
    "typescript": "^5.9.3"
  }
}
